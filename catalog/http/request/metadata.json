{
  "type": "HttpRequest",
  "label": "HTTP Request",
  "description": "Make an outbound HTTP request. Supports GET/POST/PUT/PATCH/DELETE with JSON body and custom headers.",
  "category": "http",
  "tags": [
    "http",
    "api",
    "fetch",
    "request"
  ],
  "icon": "Send",
  "color": "#06b6d4",
  "inputs": [
    {
      "name": "url",
      "type": "String",
      "required": true
    },
    {
      "name": "body",
      "type": "JsonDict",
      "required": false
    },
    {
      "name": "headers",
      "type": "Dict[String, String]",
      "required": false
    },
    {
      "name": "method",
      "type": "String",
      "required": true,
      "exposure": "config",
      "widget": {
        "kind": "select",
        "options": [
          "GET",
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "default": "GET",
      "label": "Method"
    }
  ],
  "outputs": [
    {
      "name": "status",
      "type": "Number",
      "required": false
    },
    {
      "name": "body",
      "type": "JsonDict | String",
      "required": false
    },
    {
      "name": "ok",
      "type": "Boolean",
      "required": false
    }
  ],
  "requires_infra": false
}
