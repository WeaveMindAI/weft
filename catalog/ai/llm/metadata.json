{
  "type": "Llm",
  "label": "LLM",
  "description": "Call a large language model. Supports major providers via a single interface; reports cost via the language's report_cost primitive.",
  "category": "ai",
  "tags": ["ai", "llm", "completion"],
  "icon": "Brain",
  "color": "#8b5cf6",
  "inputs": [
    { "name": "prompt", "type": "String", "required": true },
    { "name": "context", "type": "String", "required": false }
  ],
  "outputs": [
    { "name": "response", "type": "String", "required": false },
    { "name": "inputTokens", "type": "Number", "required": false },
    { "name": "outputTokens", "type": "Number", "required": false }
  ],
  "fields": [
    {
      "key": "model",
      "label": "Model",
      "field_type": { "kind": "text" },
      "required": true,
      "default_value": "claude-sonnet-4.6",
      "description": "Model identifier (e.g. claude-sonnet-4.6, gpt-4o, gemini-2.5-pro)."
    },
    {
      "key": "temperature",
      "label": "Temperature",
      "field_type": { "kind": "number", "min": 0.0, "max": 2.0 },
      "required": false,
      "default_value": 0.7
    },
    {
      "key": "maxTokens",
      "label": "Max Tokens",
      "field_type": { "kind": "number", "min": 1.0, "max": 128000.0 },
      "required": false,
      "default_value": 2000
    },
    {
      "key": "apiKey",
      "label": "API Key",
      "field_type": { "kind": "api_key", "provider": "openrouter" },
      "required": true
    }
  ],
  "entry": [],
  "requires_infra": false
}
