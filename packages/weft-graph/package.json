{
  "name": "@weft/graph",
  "version": "0.1.0",
  "description": "Shared weft graph renderer + editor. Extracted from the VS Code extension so multiple hosts render the graph from one source. Each consumer provides its own host bridge (VS Code messaging, or the dispatcher HTTP API).",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./protocol": "./src/protocol.ts",
    "./components/*": "./src/webview/lib/components/*",
    "./css": "./src/webview/app.css",
    "./status": "./src/status.ts",
    "./live-data": "./src/live-data.ts"
  },
  "peerDependencies": {
    "@xyflow/svelte": "^1.5.0",
    "elkjs": "^0.11.0",
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lucide/svelte": "^1.8.0",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "marked": "^18.0.2",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0"
  }
}