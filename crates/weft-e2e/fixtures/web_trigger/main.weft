# A live HTTP endpoint: an outside caller POSTs to /api; the responder reads the
# request body, streams progress chunks, then responds with a final JSON body
# that echoes what was sent. The rig POSTs and asserts the echoed response.

endpoint = ApiEndpoint { path: "__E2E_PATH__" }
responder = LiveHttpResponder
out = Debug

responder.started = endpoint.started
out.data = responder.done
