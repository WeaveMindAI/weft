# One real LLM call, metered end to end, on the DEPLOYMENT's key: `apiKey` is
# unset, which the runtime reads as "use the deployment's configured key" (the
# worker never holds it). The runtime measures the real cost off the real
# response. The model is asked for one exact word so the answer is assertable,
# and parseJson is off so the response is the raw string.
#
# Needs OPENROUTER_API_KEY in the environment the daemon was started from (the
# CLI packs it into the broker's secret); the cheapest model keeps the run
# nearly free.

cfg = OpenRouterConfig {
  model: "openai/gpt-4.1-nano",
  systemPrompt: "You answer with exactly one word, lowercase, no punctuation.",
  temperature: 0.0,
  maxTokens: 16
}

ask = OpenRouterInference -> (response: String) {
  prompt: "What color is a clear midday sky? Answer with one word."
}
ask.config = cfg.config

out = Debug
out.data = ask.response
