# One real LLM call on the DEPLOYMENT's key (no apiKey set), through the
# broker's provider proxy: the worker never holds the key. The model is asked
# for one exact word so the answer is assertable, and parseJson is off so the
# response is the raw string.
#
# Needs OPENROUTER_API_KEY in the environment the daemon was started from (the
# CLI packs it into the broker's secret); the cheapest model keeps the run
# nearly free.

ask = OpenRouterInference -> (response: String) {
  model: "openai/gpt-4.1-nano",
  systemPrompt: "You answer with exactly one word, lowercase, no punctuation.",
  prompt: "What color is a clear midday sky? Answer with one word.",
  temperature: 0.0,
  maxTokens: 16
}

out = Debug
out.data = ask.response
