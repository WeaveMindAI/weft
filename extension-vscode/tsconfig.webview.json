{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "types": ["svelte", "vite/client"],
    "baseUrl": ".",
    "paths": {
      // The webview lives in the shared `weft-graph` package now (extracted so the
      // website shares one renderer). The extension bundles that package source
      // into its own webview bundle via vite (using THIS app's node_modules through
      // resolve.dedupe), so its typecheck must run over the SAME package source,
      // resolving `$app/environment` to the package's shim exactly as vite does.
      "$app/environment": ["../packages/weft-graph/src/webview/shims/app-environment.ts"]
    }
  },
  "include": [
    "../packages/weft-graph/src/webview/**/*.ts",
    "../packages/weft-graph/src/webview/**/*.svelte",
    "../packages/weft-graph/src/index.ts",
    "../packages/weft-graph/src/protocol.ts"
  ],
  // Vitest specs are run by vitest (its own tsconfig/globals), not bundled into
  // the webview, so they don't belong to this typecheck.
  "exclude": ["../packages/weft-graph/src/webview/**/*.test.ts"]
}
