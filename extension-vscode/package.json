{
  "name": "weft-vscode",
  "displayName": "Weft",
  "description": "Weft language support: project management against the local dispatcher, live graph view for .weft files, runner view for .loom files, AI streaming edits.",
  "version": "0.2.0",
  "publisher": "weavemind",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "media/weft-icon.png",
  "contributes": {
    "languages": [
      {
        "id": "weft",
        "aliases": [
          "Weft",
          "weft"
        ],
        "extensions": [
          ".weft"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "loom",
        "aliases": [
          "Loom",
          "loom"
        ],
        "extensions": [
          ".loom"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "weft.openGraphView",
        "title": "Weft: Open Graph View",
        "category": "Weft"
      },
      {
        "command": "weft.openLoomView",
        "title": "Weft: Open Runner View",
        "category": "Weft"
      },
      {
        "command": "weft.runProject",
        "title": "Weft: Run Project",
        "category": "Weft"
      },
      {
        "command": "weft.followExecution",
        "title": "Weft: Follow Execution",
        "category": "Weft"
      },
      {
        "command": "weft.replayExecution",
        "title": "Weft: Replay Execution",
        "category": "Weft"
      },
      {
        "command": "weft.stopFollowing",
        "title": "Weft: Stop Following Execution",
        "category": "Weft"
      }
    ],
    "views": {
      "weft-sidebar": [
        {
          "id": "weft.projects",
          "name": "Projects"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "weft-sidebar",
          "title": "Weft",
          "icon": "media/weft-icon.png"
        }
      ]
    },
    "configuration": {
      "title": "Weft",
      "properties": {
        "weft.dispatcherUrl": {
          "type": "string",
          "default": "http://localhost:9999",
          "description": "URL of the weft dispatcher daemon the extension talks to."
        },
        "weft.parse.debounceMs": {
          "type": "number",
          "default": 100,
          "description": "Debounce between the last text change and the next /parse call that refreshes the graph view."
        },
        "weft.validate.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce between the last text change (or AI stream end) and the next /validate call that refreshes the Problems panel."
        },
        "weft.layout.debounceMs": {
          "type": "number",
          "default": 400,
          "description": "Debounce between a structural graph change and the next ELK auto-layout pass."
        },
        "weft.ai.streamingEditsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Apply SEARCH/REPLACE blocks from AI chat responses to the active .weft file in real time."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile && pnpm run bundle:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle:webview": "vite build --config vite.webview.config.mjs",
    "bundle:webview:watch": "vite build --watch --config vite.webview.config.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20",
    "@types/vscode": "^1.90.0",
    "@xyflow/svelte": "^1.5.2",
    "bits-ui": "^2.1.0",
    "clsx": "^2.1.1",
    "elkjs": "^0.9.3",
    "lucide-svelte": "^0.477.0",
    "mode-watcher": "^1.1.0",
    "svelte": "^5.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "marked": "^18.0.2"
  }
}
